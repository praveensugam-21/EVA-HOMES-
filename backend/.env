# ============================================================
# EVA Homes — Environment Variables
# ============================================================
# This file stores SECRET configuration values.
# It is listed in .gitignore so it's NEVER uploaded to GitHub.
# Each developer has their own .env file locally.
# ============================================================

# The URL that tells SQLAlchemy where our database lives.
# sqlite:///./eva_homes.db means: create a file called
# "eva_homes.db" in the current (backend) folder.
DATABASE_URL=sqlite:///./eva_homes.db

# A long random secret string used to SIGN our JWT tokens.
# If someone changes this, all existing login tokens become invalid.
# In production, use a truly random 256-bit string.
SECRET_KEY=eva-homes-super-secret-key-change-this-in-production-2024

# The algorithm used to sign JWT tokens.
# HS256 = HMAC with SHA-256 — a standard secure algorithm.
ALGORITHM=HS256

# How long (in minutes) a login token stays valid.
# After this time, the user must log in again.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App settings
APP_NAME=EVA Homes API
APP_VERSION=1.0.0
DEBUG=True
